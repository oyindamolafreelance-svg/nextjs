# --- Database (required) ---
# Postgres connection string. Free options: Supabase, Neon, Vercel Postgres.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- App security (required before deploying anywhere public) ---
# Random long string, e.g. `openssl rand -hex 32`. Signs OAuth state + login sessions.
APP_SECRET=""
# Password required to use the dashboard. Leave unset only for local-only dev.
APP_PASSWORD=""
# Fixed public URL of this deployment, used to build OAuth redirect URIs.
# e.g. https://your-app.vercel.app
APP_URL=""

# --- Cron (required for scheduled posting to actually fire) ---
# Random secret; the cron caller must send `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=""

# --- TikTok (required to connect + publish to TikTok) ---
# Create an app at https://developers.tiktok.com/apps and request the
# `user.info.basic` and `video.publish` scopes (Content Posting API).
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
# Unaudited apps can only post as SELF_ONLY (private/draft). Switch to
# PUBLIC_TO_EVERYONE once TikTok approves your app for public posting.
TIKTOK_PRIVACY_LEVEL="SELF_ONLY"

# --- Facebook (required to connect + publish to a Facebook Page) ---
# Create an app at https://developers.facebook.com/apps with Facebook Login
# and the `pages_show_list`, `pages_manage_posts`, `pages_read_engagement`
# permissions (these need App Review before they work for non-admin users).
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_GRAPH_VERSION="v21.0"

# --- AI caption generation (optional) ---
# Without this, captions fall back to a simple niche/tone template.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# --- Media uploads (optional) ---
# Vercel Blob token, so you can upload files from the compose screen instead
# of pasting a hosted media URL. Create a Blob store in your Vercel project.
BLOB_READ_WRITE_TOKEN=""
